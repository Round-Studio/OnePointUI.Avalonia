<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:onePointControls="clr-namespace:OnePointUI.Avalonia.Styling.Controls.OnePointControls;assembly=OnePointUI.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="900"
             x:Class="OnePointUI.Avalonia.Test.Pages.BasicControls">
    <ScrollViewer>
        <StackPanel Margin="10" Spacing="8">

            <onePointControls:LineTextBlock Text="基础按钮 / 切换按钮 / 单选" FontSize="18" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Width="120" Height="36">Button</Button>
                <Button Width="120" Height="36" Classes="Accent">Accent</Button>
                <Button Width="120" Height="36" Classes="Subtle">Subtle</Button>
                <Button Width="120" Height="36" Classes="NoBorder">NoBorder</Button>
                <ToggleButton Width="120" Height="36" Content="Toggle" />
                <ToggleButton Width="120" Height="36" Content="Checked" IsChecked="True" />
                <RepeatButton Width="120" Height="36" Content="Repeat" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <RadioButton GroupName="g1" Content="Radio A" />
                <RadioButton GroupName="g1" Content="Radio B" IsChecked="True" />
                <RadioButton GroupName="g1" Content="Radio C" IsEnabled="False" />
            </StackPanel>

            <Separator />

            <onePointControls:LineTextBlock Text="输入 / 数值 / 自动完成" FontSize="18" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBox Width="180" Watermark="搜索..." />
                <NumericUpDown Width="160" Minimum="0" Maximum="100" Value="42" FormatString="N0" />
                <AutoCompleteBox Width="200" Watermark="搜索..." />
            </StackPanel>

            <Separator />

            <onePointControls:LineTextBlock Text="日期 / 时间 / 日历" FontSize="18" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
                <DatePicker />
                <TimePicker />
                <CalendarDatePicker />
            </StackPanel>

            <Separator />

            <onePointControls:LineTextBlock Text="选择 / 列表" FontSize="18" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
                <CheckBox IsChecked="True">CheckBox</CheckBox>
                <CheckBox>CheckBox</CheckBox>
                <CheckBox IsEnabled="False">Disabled</CheckBox>
                <ToggleSwitch />
                <ComboBox SelectedIndex="0" Width="160">
                    <ComboBoxItem>Item A</ComboBoxItem>
                    <ComboBoxItem>Item B</ComboBoxItem>
                    <ComboBoxItem>Item C</ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <Separator />

            <onePointControls:LineTextBlock Text="滑动 / 进度" FontSize="18" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Slider Width="220" Minimum="0" Maximum="100" Value="50" />
                <ProgressBar Width="220" Value="60" Minimum="0" Maximum="100" />
                <onePointControls:ProgressRing Width="36" Height="36" />
            </StackPanel>

            <Separator />

            <onePointControls:LineTextBlock Text="菜单 / 弹出" FontSize="18" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Menu>
                    <MenuItem Header="_File">
                        <MenuItem Header="_New" InputGesture="Ctrl+N" />
                        <MenuItem Header="_Open" InputGesture="Ctrl+O" />
                        <Separator />
                        <MenuItem Header="E_xit" />
                    </MenuItem>
                    <MenuItem Header="_Edit">
                        <MenuItem Header="_Cut" InputGesture="Ctrl+X" />
                        <MenuItem Header="_Copy" InputGesture="Ctrl+C" />
                    </MenuItem>
                </Menu>

                <Button Content="右键我"
                        ToolTip.Tip="这是一个 Tooltip 提示"
                        Width="120" Height="36">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="操作 1" />
                            <MenuItem Header="操作 2" />
                            <Separator />
                            <MenuItem Header="关闭" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </StackPanel>

            <Separator />

            <onePointControls:LineTextBlock Text="树 / 轮播 / 分割" FontSize="18" FontWeight="Bold" />
            <Grid ColumnDefinitions="*,8,*,8,*" Height="180">
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource PrimaryBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TreeView>
                        <TreeViewItem Header="Item 1" IsExpanded="True">
                            <TreeViewItem Header="Item 1.1" />
                            <TreeViewItem Header="Item 1.2" />
                        </TreeViewItem>
                        <TreeViewItem Header="Item 2" />
                        <TreeViewItem Header="Item 3" IsEnabled="False" />
                    </TreeView>
                </Border>

                <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="{DynamicResource PrimaryBorderBrush}" />

                <Carousel Grid.Column="2">
                    <Border Background="{DynamicResource AccentLighterBrush}" />
                    <Border Background="{DynamicResource AccentLightBrush}" />
                    <Border Background="{DynamicResource AccentBackgroundBrush}" />
                </Carousel>

                <GridSplitter Grid.Column="3" ResizeDirection="Columns" Background="{DynamicResource PrimaryBorderBrush}" />

                <SplitView Grid.Column="4" IsPaneOpen="True" DisplayMode="Inline" OpenPaneLength="80">
                    <SplitView.Pane>
                        <Border Background="{DynamicResource BackgroundSecondaryBrush}">
                            <TextBlock Text="侧边栏" Margin="8" />
                        </Border>
                    </SplitView.Pane>
                    <Border Background="{DynamicResource BackgroundBrush}">
                        <TextBlock Text="主内容" Margin="8" />
                    </Border>
                </SplitView>
            </Grid>

            <Separator />

            <onePointControls:LineTextBlock Text="路径图标 / 颜色选择" FontSize="18" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Width="28" Height="28"
                          Data="M 12 2 L 22 22 L 2 22 Z"
                          Foreground="{DynamicResource AccentBackgroundBrush}" />
                <PathIcon Width="28" Height="28"
                          Data="M 4 4 L 20 4 L 20 20 L 4 20 Z"
                          Foreground="{DynamicResource AccentLightBrush}" />
                <PathIcon Width="28" Height="28"
                          Data="M 12 2 A 10 10 0 1 0 12 22 A 10 10 0 1 0 12 2"
                          Foreground="{DynamicResource AccentDarkBrush}" />
                <Border Width="200" Height="80"
                        Background="{DynamicResource AccentSubtleBrush}"
                        CornerRadius="6">
                    <TextBlock Text="主题色微调" Margin="12" />
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
